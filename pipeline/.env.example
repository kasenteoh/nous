# Pipeline environment configuration.
# Copy to `.env` (gitignored) and fill in the values for local development.
# Production values are stored as GitHub Actions secrets and Vercel env vars.

# ─────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection URL. Must use the `postgresql+psycopg://` scheme
# (psycopg 3 async driver, used by SQLAlchemy 2.x async).
#
# For local dev with a Docker Postgres:
#   docker run --rm -d --name nous-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:15
#   DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
#
# For Supabase: use the **Session pooler** connection string (port 5432,
# IPv4) and rewrite the scheme to `postgresql+psycopg://`. The direct/IPv6
# endpoint does not work from GitHub Actions runners.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

# User-Agent contact string sent on all outbound scraping (homepages, news,
# VC portfolios). Must include a contact email — many sites block anonymous
# traffic, and robots.txt etiquette expects an identifiable agent.
SEC_USER_AGENT=nous-project your-email@example.com

# ─────────────────────────────────────────────────────────────────────────────
# M2+ — homepage scraping + LLM enrichment
# ─────────────────────────────────────────────────────────────────────────────

# DeepSeek API key. Required — all LLM calls run on DeepSeek's
# OpenAI-compatible API. Paid (~$0.27/1M input + $1.10/1M output); this
# bypasses the spec's "free tier first" rule because Gemini's free tier
# (20 RPD) was too low for bulk enrichment.
# Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# M3 — news ingestion + funding extraction + VC portfolio discovery
# ─────────────────────────────────────────────────────────────────────────────

# pg_trgm similarity threshold for fuzzy company-name matching in
# auto_create_company (VC portfolios, news, TechCrunch). 0.85 is the M3
# default; lower catches more near-misses, raise reduces false positives.
# COMPANY_FUZZY_MATCH_THRESHOLD=0.85

# ─────────────────────────────────────────────────────────────────────────────
# Used by later milestones; leave blank for M3
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VERCEL_DEPLOY_HOOK_URL=
