# Pipeline environment configuration.
# Copy to `.env` (gitignored) and fill in the values for local development.
# Production values are stored as GitHub Actions secrets and Vercel env vars.

# ─────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection URL. Must use the `postgresql+psycopg://` scheme
# (psycopg 3 async driver, used by SQLAlchemy 2.x async).
#
# For local dev with a Docker Postgres:
#   docker run --rm -d --name nous-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:15
#   DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
#
# For Supabase: use the **Session pooler** connection string (port 5432,
# IPv4) and rewrite the scheme to `postgresql+psycopg://`. The direct/IPv6
# endpoint does not work from GitHub Actions runners.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

# SEC EDGAR requires a User-Agent header containing a contact email.
# Anonymous traffic is blocked.
SEC_USER_AGENT=nous-project your-email@example.com

# ─────────────────────────────────────────────────────────────────────────────
# Optional overrides (defaults shown)
# ─────────────────────────────────────────────────────────────────────────────

# Industry groups to keep from Form D filings. JSON array string.
# INDUSTRY_GROUPS='["Technology - Computers","Technology - Other","Technology - Telecommunications"]'

# Extra days to look back beyond the requested window, to catch late filings
# and EDGAR indexing delays.
# EDGAR_OVERLAP_DAYS=14

# EDGAR rate-limit ceiling. SEC permits up to 10 req/s; default leaves headroom.
# EDGAR_REQUESTS_PER_SECOND=5.0

# ─────────────────────────────────────────────────────────────────────────────
# Used by later milestones (M2+); leave blank for M1
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
VERCEL_DEPLOY_HOOK_URL=
